# ---------- shared ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

# ---------- liteLLM ----------
# Must start with sk-
LITELLM_MASTER_KEY=sk-change-me
LITELLM_IMAGE_TAG=main-stable
LITELLM_PORT=4000
LITELLM_LOG=ERROR

# Provider keys - fill only the ones you actually use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
SLACK_WEBHOOK_URL=

# ---------- paperclip ----------
PAPERCLIP_PORT=3100
PAPERCLIP_AGENT_JWT_SECRET=replace-with-a-long-random-secret
# Use authenticated for remote deployment. Paperclip's docs recommend
# authenticated + public for internet-facing deployment.
PAPERCLIP_DEPLOYMENT_MODE=authenticated

# ---------- agent zero ----------
AGENTZERO_IMAGE=agent0ai/agent-zero
AGENTZERO_PORT=50080
AGENTZERO_AUTH_LOGIN=admin
AGENTZERO_AUTH_PASSWORD=change-me-too
A0_SET_agent_profile=custom
A0_SET_agent_memory_subdir=production

# ---------- bridge ----------
WORKER_GATEWAY_PORT=8080
WORKER_GATEWAY_LOG_LEVEL=info
# Agent Zero API token — retrieve from Agent Zero UI: Settings > External Services
# Leave empty until first boot; the gateway will log a warning and skip A0 calls.
AGENTZERO_API_TOKEN=
