# ---------- shared ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=postgres

# ---------- liteLLM ----------
# Must start with sk-
LITELLM_MASTER_KEY=sk-change-me
LITELLM_IMAGE_TAG=main-stable
LITELLM_PORT=4000
LITELLM_LOG=ERROR

# Provider keys - fill only the ones you actually use
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
SLACK_WEBHOOK_URL=

# ---------- paperclip ----------
PAPERCLIP_PORT=3100
PAPERCLIP_AGENT_JWT_SECRET=replace-with-a-long-random-secret
# Docker local dev uses Paperclip's authenticated/private LAN bind so the UI is
# reachable on localhost:3100. On first boot, the container will print a
# bootstrap/claim URL in the Paperclip startup logs after migrations finish.
# For internet-facing deployment, keep authenticated and set
# PAPERCLIP_PUBLIC_URL to your public domain.
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# ---------- agent zero ----------
AGENTZERO_IMAGE=agent0ai/agent-zero
AGENTZERO_PORT=50080
AGENTZERO_AUTH_LOGIN=admin
AGENTZERO_AUTH_PASSWORD=change-me-too
A0_SET_agent_profile=custom
A0_SET_agent_memory_subdir=production

# ---------- bridge ----------
WORKER_GATEWAY_PORT=8080
WORKER_GATEWAY_LOG_LEVEL=info
# Agent Zero API token — retrieve from Agent Zero UI: Settings > External Services
# Leave empty until first boot; the gateway will log a warning and skip A0 calls.
AGENTZERO_API_TOKEN=

# ---------- dashboard ----------
DASHBOARD_PORT=3000
BETTER_AUTH_SECRET=change-me-better-auth-secret

# ---------- connectors ----------
# Fernet key for encrypting connector credentials at rest
# Generate with: python -c 'from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())'
CONNECTOR_ENCRYPTION_KEY=
# Shared secret for internal service-to-service auth (gateway <-> MCP servers)
GATEWAY_INTERNAL_SECRET=change-me-internal

# Google OAuth (for Gmail connector)
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
